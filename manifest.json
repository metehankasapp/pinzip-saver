{
  "manifest_version": 3,
  "name": "PinZip Saver",
  "version": "1.3.1",
  "description": "Select image pins on the page and save the largest available versions as one ZIP.",
  "host_permissions": [
    "https://pinterest.com/*",
    "https://*.pinterest.com/*",
    "https://*.pinimg.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://pinterest.com/*",
        "https://*.pinterest.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_title": "PinZip Saver",
    "default_popup": "popup.html"
  }
}
